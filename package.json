{
  "name": "jmart-steel-safety-app",
  "version": "2.0.0",
  "description": "JMart Steel Safety Management App - Pre-Start Checklists, Site Inspections, ITP Forms, Toolbox Talks, and Incident Reports",
  "main": "index.html",
  "scripts": {
    "build": "node scripts/build-jsx.js && node scripts/build-dist.js",
    "lint": "eslint js/components/*.jsx js/*.js",
    "lint:fix": "eslint js/components/*.jsx js/*.js --fix",
    "backup:drive": "python scripts/backup-safety-data-to-drive.py",
    "backup:register-task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-bimonthly-backup-task.ps1",
    "backfill:auth-devices": "node scripts/backfill-auth-devices.js",
    "migrate:forms": "node scripts/migrate-legacy-forms.js",
    "migrate:forms:write": "node scripts/migrate-legacy-forms.js --write",
    "reconcile:jobs": "python scripts/reconcile-jobs-from-sites.py",
    "recover:admin": "node scripts/recover-admin-device.js",
    "test": "jest",
    "test:hub": "jest tests/unit/hub",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "validate": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "safety",
    "pwa",
    "construction",
    "compliance"
  ],
  "author": "JMart Steel",
  "license": "PRIVATE",
  "devDependencies": {
    "@babel/core": "7.24.0",
    "@babel/preset-env": "7.24.0",
    "@babel/preset-react": "7.23.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "firebase-tools": "^15.11.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
