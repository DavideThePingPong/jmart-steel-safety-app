{
  "database": {
    "rules": "firebase.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase.rules.json",
      "**/.*",
      "**/node_modules/**",
      "CRITICAL-SAFETY-REVIEW.md",
      "TEST-COVERAGE-ANALYSIS.md",
      "DOCUMENTATION.md",
      "README.md",
      "package.json",
      "package-lock.json",
      "babel.config.js",
      "jest.config.js",
      "JMart-Codebase-Analysis-Report.docx",
      "**/src/**",
      "**/src-v3/**",
      "**/tests/**",
      "**/.github/**",
      "CLAUDE.md",
      "generate-sri-hashes.sh",
      "**/*.docx"
    ],
    "headers": [
      {
        "source": "reset.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "none"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Permissions-Policy",
            "value": "geolocation=(self), camera=(self), microphone=(self)"
          },
          {
            "key": "X-Content-Security-Policy-Note",
            "value": "CSP is defined via meta tag in index.html — not here — to avoid stale header caching"
          }
        ]
      }
    ]
  }
}
