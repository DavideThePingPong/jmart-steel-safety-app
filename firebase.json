{
  "functions": {
    "source": "functions"
  },
  "database": {
    "rules": "firebase.rules.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "firebase.rules.json",
      "**/.*",
      "**/node_modules/**",
      "**/js/components/*.jsx",
      "**/js/vendor/**",
      "**/*.pdf"
    ],
    "rewrites": [
      {
        "source": "api/hanna/scan-receipt",
        "function": {
          "functionId": "hannaScanReceipt",
          "region": "australia-southeast1",
          "pinTag": true
        }
      },
      {
        "source": "api/victor/search-msds",
        "function": {
          "functionId": "victorSearchMsds",
          "region": "australia-southeast1",
          "pinTag": true
        }
      },
      {
        "source": "api/victor/analyze-sds",
        "function": {
          "functionId": "victorAnalyzeSds",
          "region": "australia-southeast1",
          "pinTag": true
        }
      },
      {
        "source": "api/frank/search-regulations",
        "function": {
          "functionId": "frankSearchRegulations",
          "region": "australia-southeast1",
          "pinTag": true
        }
      },
      {
        "source": "api/frank/generate-swms",
        "function": {
          "functionId": "frankGenerateSwms",
          "region": "australia-southeast1",
          "pinTag": true
        }
      },
      {
        "source": "api/frank/extract-requirements",
        "function": {
          "functionId": "frankAttachmentExtract",
          "region": "australia-southeast1",
          "pinTag": true
        }
      }
    ],
    "headers": [
      {
        "source": "reset.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "none"
          }
        ]
      },
      {
        "source": "/",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
        ]
      },
      {
        "source": "/artsteel-hub.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
        ]
      },
      {
        "source": "/hub-sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Permissions-Policy",
            "value": "geolocation=(self), camera=(self), microphone=(self)"
          },
          {
            "key": "X-Content-Security-Policy-Note",
            "value": "CSP is defined via meta tag in index.html — not here — to avoid stale header caching"
          }
        ]
      }
    ]
  }
}
