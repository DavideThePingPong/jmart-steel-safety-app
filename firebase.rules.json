{
  "rules": {
    // DEFAULT DENY — anything not explicitly allowed is blocked
    ".read": false,
    ".write": false,

    "jmart-safety": {
      // Admin Auth UIDs — maps Firebase auth UIDs to admin status
      // Only writable by existing admins or during first-device setup (no approved devices yet)
      "adminAuthUids": {
        ".read": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()",
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('jmart-safety/adminAuthUids/' + auth.uid).exists())",
          // Allow write only if: (a) writer is existing admin in adminAuthUids, OR
          // (b) no approved devices exist yet (first-device setup)
          ".write": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || !root.child('jmart-safety/devices/approved').exists())",
          ".validate": "newData.isBoolean()"
        }
      },

      "authDevices": {
        ".read": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()",
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('jmart-safety/adminAuthUids/' + auth.uid).exists())",
          ".write": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || (auth.uid === $uid && newData.child('deviceId').isString() && root.child('jmart-safety/devices/approved/' + newData.child('deviceId').val()).child('authUid').val() === auth.uid))",
          // isAdmin is immutable for self-writes — only existing admins can change it.
          // This prevents a non-admin self-writer from claiming admin via this map.
          ".validate": "!newData.exists() || (newData.hasChildren(['deviceId', 'approvedAt', 'lastSeen']) && newData.child('deviceId').isString() && newData.child('approvedAt').isString() && newData.child('lastSeen').isString() && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || !data.exists() || newData.child('isAdmin').val() === data.child('isAdmin').val()))"
        }
      },

      // Config - authenticated devices can read; only admins or first-time setup can write
      "config": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.child('appPasswordHash').exists() || root.child('jmart-safety/adminAuthUids/' + auth.uid).exists())"
      },

      // Devices - hierarchical structure: devices/approved/{id}, devices/pending/{id}, devices/denied/{id}
      "devices": {
        "approved": {
          ".read": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || !data.exists())",
          "$deviceId": {
            ".read": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || !data.exists() || data.child('authUid').val() === auth.uid)",
            // Allow write ONLY if:
            //   (a) No approved devices exist yet (first-device setup), OR
            //   (b) Writer is an existing admin (auth.uid in adminAuthUids), OR
            //   (c) Writer is updating their own existing approved record (authUid matches)
            ".write": "auth != null && (!root.child('jmart-safety/devices/approved').exists() || root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || (data.exists() && data.child('authUid').val() === auth.uid))",
            // CRITICAL — privilege flag immutability. A non-admin updating their
            // own record (rule case c above) MUST NOT be able to flip isAdmin,
            // canRevokeDevices, or canViewDevices to true. Only existing admins
            // (writer in adminAuthUids) OR first-device bootstrap (no approved
            // devices yet) can change those flags. Closes the self-promotion bug.
            ".validate": "!newData.exists() || root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || !root.child('jmart-safety/devices/approved').exists() || !data.exists() || ((newData.child('isAdmin').val() === data.child('isAdmin').val() || (!newData.child('isAdmin').exists() && !data.child('isAdmin').exists())) && (newData.child('canRevokeDevices').val() === data.child('canRevokeDevices').val() || (!newData.child('canRevokeDevices').exists() && !data.child('canRevokeDevices').exists())) && (newData.child('canViewDevices').val() === data.child('canViewDevices').val() || (!newData.child('canViewDevices').exists() && !data.child('canViewDevices').exists())))"
          }
        },
        "pending": {
          ".read": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()",
          "$deviceId": {
            ".read": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || !data.exists() || data.child('authUid').val() === auth.uid)",
            // Allow write for:
            //   (a) Self-registration (new data where authUid matches auth.uid), OR
            //   (b) Admin operations (approve/deny/cleanup/deletion), OR
            //   (c) Own device deletion (owner can remove their own pending entry)
            ".write": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || (newData.exists() && newData.child('authUid').val() === auth.uid) || (!newData.exists() && data.child('authUid').val() === auth.uid))"
          }
        },
        "denied": {
          ".read": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()",
          "$deviceId": {
            ".read": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()",
            // Only admins can deny devices
            ".write": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()"
          }
        },
        // Legacy flat device entries (for migration) - admin or self-migration only
        "$deviceId": {
          ".read": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || !data.exists() || data.child('authUid').val() === auth.uid)",
          ".write": "auth != null && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || (data.exists() && data.child('authUid').val() === auth.uid) || !root.child('jmart-safety/devices/approved').exists())"
        }
      },

      // Forms - any authenticated device can read/write (password is the gate)
      "forms": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        "$formId": {
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
          ".validate": "!newData.exists() || (newData.hasChildren(['id', 'type', 'createdAt', 'createdBy', '_lastModified', '_modifiedBy']) && newData.child('id').isString() && newData.child('id').val() === $formId && newData.child('type').isString() && newData.child('type').val().length < 100 && newData.child('createdAt').isString() && newData.child('createdBy').isString() && newData.child('createdBy').val().length < 200 && newData.child('_lastModified').isNumber() && newData.child('_modifiedBy').isString() && (!data.exists() || newData.child('createdAt').val() === data.child('createdAt').val()) && (!data.exists() || newData.child('createdBy').val() === data.child('createdBy').val()))"
        }
      },

      "formAssets": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        "$formId": {
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()"
        }
      },

      // Jobs - managed job entries for forms and photo uploads
      "jobs": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        ".write": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()"
      },

      // Sites - any authenticated device can read; only admins can replace the shared list
      "sites": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        ".write": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()"
      },

      // Training - any authenticated device can read/write
      "training": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        "$recordId": {
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
          ".validate": "newData.hasChildren(['type', 'createdAt']) && newData.child('type').isString() && newData.child('type').val().length < 200"
        }
      },

      // Victor - MSDS products (authenticated devices only)
      "victor": {
        "products": {
          ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
          "$productId": {
            ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
            ".validate": "!newData.exists() || (newData.hasChildren(['name', 'manufacturer', 'msds_url']) && newData.child('name').isString() && newData.child('name').val().length < 300 && newData.child('manufacturer').isString() && newData.child('manufacturer').val().length < 300 && newData.child('msds_url').isString() && newData.child('msds_url').val().length < 2000)"
          }
        }
      },

      // Frank - SWMS history, memory, and regulation updates (authenticated devices only)
      "frank": {
        "history": {
          ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
          "$recordId": {
            ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
            ".validate": "newData.hasChildren(['jobDesc', 'date', 'createdAt', 'swmsData']) && !newData.hasChild('html') && newData.child('jobDesc').isString() && newData.child('jobDesc').val().length < 500 && newData.child('date').isString() && newData.child('createdAt').isString() && newData.child('swmsData').hasChildren(['title', 'steps'])"
          }
        },
        "memory": {
          ".read": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()",
          ".write": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()"
        },
        "regulation-updates": {
          ".read": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()",
          ".write": "auth != null && root.child('jmart-safety/adminAuthUids/' + auth.uid).exists()"
        }
      },

      // Igor - pricing data (authenticated devices only)
      "igor": {
        "pricing": {
          ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()"
        }
      },

      // Hanna - Receipts (any approved device — boss's non-admin hub needs
      // to scan too). Validate now requires store_name + total to be present
      // and correctly typed; previously a partial OCR result with garbage
      // types could write through and crash the recent-list rendering on
      // `.toFixed`. ID accepts string OR number (client now generates string
      // ids with random suffix so two devices saving in the same ms don't
      // collide on Date.now()).
      "hanna": {
        "receipts": {
          ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
          "$receiptId": {
            ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
            ".validate": "!newData.exists() || (newData.hasChildren(['id', 'saved_at', 'store_name', 'total']) && (newData.child('id').isString() || newData.child('id').isNumber()) && newData.child('saved_at').isString() && newData.child('saved_at').val().length < 100 && newData.child('store_name').isString() && newData.child('store_name').val().length < 240 && newData.child('total').isNumber() && newData.child('total').val() >= 0 && newData.child('total').val() < 1000000)"
          }
        }
      },

      // Pre-Start Templates - synced across all approved devices
      "prestartTemplates": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()"
      },

      // Notifications - authenticated devices can read/write
      "notifications": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        "$notifId": {
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
          ".validate": "newData.val().length < 10000"
        }
      },

      // Deleted-form tombstones — persistent record of deletions so the
      // Firebase listener can suppress resurrection of forms that were
      // deleted by another device or in a prior session whose local
      // deletedFormIdsRef is no longer in localStorage. Append-only:
      // writes only allowed if the entry doesn't already exist.
      "deletedForms": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        "$formId": {
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists() && !data.exists()",
          ".validate": "newData.hasChildren(['deletedAt', 'deletedBy']) && newData.child('deletedAt').isNumber() && newData.child('deletedBy').isString()"
        }
      },

      // Daily backup lock — distributed coordination for the 7pm scheduler.
      // First device to write the lock for a given date wins; others bail.
      // Approved devices can claim the lock; nobody (not even admins via this
      // path) should overwrite an existing lock until it expires (handled
      // client-side by date key, so each new day creates a fresh entry).
      "backupLock": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        "$dateKey": {
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists() && (!data.exists() || newData.child('deviceId').val() === data.child('deviceId').val())",
          ".validate": "newData.hasChildren(['deviceId', 'claimedAt']) && newData.child('deviceId').isString() && newData.child('claimedAt').isNumber()"
        }
      },

      // Audit log - any authenticated user can read, append only (no deletes/updates)
      "auditLog": {
        ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
        "$logId": {
          ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists() && !data.exists()",
          // Bind deviceId to the writer's auth UID via authDevices mapping.
          // Closes the impersonation gap where a malicious device could log
          // entries claiming to be a different device. Append-only is enforced
          // by !data.exists() in the .write rule above; this validate locks
          // the deviceId to the actual writer.
          ".validate": "newData.hasChildren(['action', 'deviceId', 'timestamp']) && newData.child('action').isString() && newData.child('action').val().length < 500 && newData.child('deviceId').isString() && newData.child('timestamp').isNumber() && (root.child('jmart-safety/adminAuthUids/' + auth.uid).exists() || newData.child('deviceId').val() === root.child('jmart-safety/authDevices/' + auth.uid).child('deviceId').val())"
        }
      }
    },

    // Signatures - any approved device can read/write the shared map
    "signatures": {
      ".read": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
      ".write": "auth != null && root.child('jmart-safety/authDevices/' + auth.uid).child('approvedAt').exists()",
      "$signatureId": {
        // Per-entry cap reduced from 500 KB → 150 KB (no signature image needs
        // more — a typical 800px PNG is 30-50 KB). Combined with the key
        // length cap, an insider can no longer balloon Firebase storage by
        // writing thousands of huge garbage-keyed entries.
        // Key length cap (≤ 200 chars) prevents signatures/AAAA…AAAA junk.
        ".validate": "!newData.exists() || newData.val() === null || (newData.isString() && newData.val().length < 150000 && $signatureId.length < 200)"
      }
    }
  }
}
